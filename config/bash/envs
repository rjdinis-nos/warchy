# Warchy Bin PATH (XDG-compliant)
PATH="$HOME/.local/bin/warchy:$PATH"
PATH="$HOME/.local/bin/warchy/apps:$PATH"
PATH="$HOME/.local/bin/warchy/utils:$PATH"
PATH="$HOME/.local/bin/warchy/install:$PATH"

# WSL
export LIBVA_DRIVER_NAME=d3d12

# Editor used by CLI
export EDITOR=nvim
export SUDO_EDITOR="$EDITOR"

# GPG Settings
export GPG_TTY=$(tty)
export GNUPGHOME="$HOME/.ssh/gnupg"

# SSH Agent — keychain manages the socket when installed; fall back to systemd
if ! command -v keychain &> /dev/null; then
  export SSH_AUTH_SOCK="${XDG_RUNTIME_DIR}/ssh-agent.socket"
fi

# SSH askpass — GUI passphrase prompt for non-TTY contexts (e.g. agents, tools)
export SSH_ASKPASS=/usr/bin/lxqt-openssh-askpass
# SSH_ASKPASS_REQUIRE=prefer is set in init after keychain loads keys interactively

# App Settings
export BAT_THEME=ansi
export FZF_DEFAULT_OPTS='--height 30 --reverse --prompt "Select> " --ansi'
export WGETRC="$XDG_CONFIG_HOME/wget/wgetrc"
export DOCKER_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/docker"
export DOTNET_CLI_HOME="${XDG_CONFIG_HOME:-$HOME/.config}/dotnet"

# Golang config
export GOPATH="${XDG_DATA_HOME:-$HOME/.local/share}/go"
export GOBIN="$GOPATH/bin"
export GOCACHE="${XDG_CACHE_HOME:-$HOME/.cache}/go-build"
export PATH="$PATH:$GOBIN"

# Opencode PATH
export PATH="$HOME/.opencode/bin:$PATH"

# Python — XDG-compliant history (requires Python 3.13+)
export PYTHON_HISTORY="${XDG_STATE_HOME:-$HOME/.local/state}/python/python_history"
