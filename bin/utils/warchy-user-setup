#!/usr/bin/env bash
set -euo pipefail

echo -e "\e[32mв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\e[0m"
echo -e "\e[32m  Warchy User Setup\e[0m"
echo -e "\e[32mв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\e[0m"
echo

# Check required commands
for cmd in vhdm git gum wslpath; do
    if ! command -v "$cmd" &> /dev/null; then
        echo -e "\e[31mвң— Error: $cmd is required but not installed\e[0m"
        exit 1
    fi
done

#=== VHD Configuration ===
echo -e "\e[36mвҡҷ  VHD Configuration\e[0m"
echo

# Initialize variables
MOUNT_POINT=""
SKIP_VHD=0

# Check if ~/.ssh exists and has SSH keys
SSH_DIR_HAS_KEYS=0
if [[ -d "$HOME/.ssh" ]] && ls "$HOME/.ssh"/id_* 2>/dev/null | grep -v '\.pub$' > /dev/null; then
  SSH_DIR_HAS_KEYS=1
  gum style --foreground 245 "  вҶ’ SSH keys already exist in ~/.ssh"
fi

# Check if VHD is already mounted at ~/.ssh
MOUNTED_VHD=""
if command -v vhdm &> /dev/null; then
  MOUNTED_VHD=$(vhdm status --mount-point "$HOME/.ssh" 2>/dev/null | grep "Path" | sed 's/.*: //' || echo "")
  if [[ -n "$MOUNTED_VHD" ]]; then
    gum style --foreground 245 "  вҶ’ VHD already mounted: $MOUNTED_VHD"
  fi
fi

# Determine what to ask
if [[ "$SSH_DIR_HAS_KEYS" -eq 1 ]] && [[ -z "$MOUNTED_VHD" ]]; then
  # Keys exist but no VHD mounted - ask if user wants to mount to alternate location
  if ! gum confirm --show-help=false --affirmative "Yes" --negative "Skip" "Mount VHD to alternate location?"; then
    gum style --foreground 245 "  вҶ’ Skipped VHD configuration"
    SKIP_VHD=1
  else
    SKIP_VHD=0
    DEFAULT_MOUNT="/mnt/vhd-ssh"
  fi
elif [[ -n "$MOUNTED_VHD" ]]; then
  # VHD already mounted - ask if user wants to reconfigure
  if ! gum confirm --show-help=false --affirmative "Reconfigure" --negative "Skip" "Reconfigure VHD mount?"; then
    gum style --foreground 245 "  вҶ’ Skipped VHD configuration"
    SKIP_VHD=1
  else
    SKIP_VHD=0
    DEFAULT_MOUNT="$HOME/.ssh"
  fi
else
  # No keys and no VHD - ask if user wants to mount
  if ! gum confirm --show-help=false --affirmative "Yes" --negative "Skip" "Mount VHD with SSH keys?"; then
    gum style --foreground 245 "  вҶ’ Skipped VHD configuration"
    SKIP_VHD=1
  else
    SKIP_VHD=0
    DEFAULT_MOUNT="$HOME/.ssh"
  fi
fi

# Only proceed if user wants to configure VHD
if [[ "$SKIP_VHD" -eq 0 ]]; then
  # Prompt for VHD path with validation
  while true; do
    if [[ -n "$MOUNTED_VHD" ]]; then
      VHD_PATH_INPUT=$(gum input --prompt "  VHD path (Windows or WSL): " --value "$MOUNTED_VHD")
    else
      VHD_PATH_INPUT=$(gum input --prompt "  VHD path (Windows or WSL): " --placeholder "C:\\Path\\To\\file.vhdx")
    fi
    
    # Convert Windows path to WSL path for validation
    VHD_PATH=$(wslpath "$VHD_PATH_INPUT" 2>/dev/null || echo "$VHD_PATH_INPUT")
    
    # Check if file exists (using WSL path)
    if [[ -f "$VHD_PATH" ]]; then
      gum style --foreground 245 "  вҶ’ VHD file found: $VHD_PATH"
      break
    else
      gum style --foreground 1 "  вң— VHD file not found: $VHD_PATH"
    fi
  done

  MOUNT_POINT=$(gum input --prompt "  Mount point: " --value "$DEFAULT_MOUNT")
  gum style --foreground 245 "  вҶ’ Mount point: $MOUNT_POINT"

  # Mount VHD (vhdm requires Windows path format)
  gum style --foreground 245 "  вҶ’ Mounting VHD..."
  vhdm mount --vhd-path "$VHD_PATH_INPUT" --mount-point "$MOUNT_POINT"
  gum style --foreground 82 "вң”  VHD mounted successfully"
fi

#=== Git Configuration ===
echo
echo -e "\e[36mвҡҷ  Git Configuration\e[0m"
echo

# Get current git config values
CURRENT_NAME=$(git config --global user.name 2>/dev/null || echo "")
CURRENT_EMAIL=$(git config --global user.email 2>/dev/null || echo "")
_cur_sign_key_preview=$(git config --global user.signingkey 2>/dev/null || echo "")
_cur_sign_fmt_preview=$(git config --global gpg.format 2>/dev/null || echo "gpg")

# Show current status and ask if user wants to configure
if [[ -n "$CURRENT_NAME" ]] || [[ -n "$CURRENT_EMAIL" ]]; then
  [[ -n "$CURRENT_NAME" ]] && gum style --foreground 245 "  вҶ’ Current name: $CURRENT_NAME"
  [[ -n "$CURRENT_EMAIL" ]] && gum style --foreground 245 "  вҶ’ Current email: $CURRENT_EMAIL"
  if [[ -n "$_cur_sign_key_preview" ]]; then
    gum style --foreground 245 "  вҶ’ Signing key (${_cur_sign_fmt_preview}): ${_cur_sign_key_preview}"
  fi
  
  if ! gum confirm --show-help=false --affirmative "Reconfigure" --negative "Skip" "Reconfigure Git settings?"; then
    gum style --foreground 245 "  вҶ’ Skipped Git configuration"
    SKIP_GIT=1
  else
    SKIP_GIT=0
  fi
else
  if ! gum confirm --show-help=false --affirmative "Yes" --negative "Skip" "Configure Git settings?"; then
    gum style --foreground 245 "  вҶ’ Skipped Git configuration"
    SKIP_GIT=1
  else
    SKIP_GIT=0
  fi
fi

# Only proceed if user wants to configure Git
if [[ "$SKIP_GIT" -eq 0 ]]; then
  # Prompt for Git name with current value as default
  if [[ -n "$CURRENT_NAME" ]]; then
    GIT_NAME=$(gum input --prompt "  Full name: " --value "$CURRENT_NAME")
  else
    GIT_NAME=$(gum input --prompt "  Full name: " --placeholder "John Doe")
  fi
  gum style --foreground 245 "  вҶ’ Git user name: $GIT_NAME"

  # Prompt for Git email with current value as default
  if [[ -n "$CURRENT_EMAIL" ]]; then
    GIT_EMAIL=$(gum input --prompt "  Email address: " --value "$CURRENT_EMAIL")
  else
    GIT_EMAIL=$(gum input --prompt "  Email address: " --placeholder "john@example.com")
  fi
  gum style --foreground 245 "  вҶ’ Git user email: $GIT_EMAIL"

  # Configure Git identity
  git config --global user.name "$GIT_NAME"
  git config --global user.email "$GIT_EMAIL"

  gum style --foreground 82 "вң”  Git configured successfully"
fi

#=== Git Signing Configuration ===
echo
echo -e "\e[36mвҡҷ  Git Signing\e[0m"
echo

_SSH_SIGNING_PUBKEY=""
_cur_sign_key=$(git config --global user.signingkey 2>/dev/null || echo "")
_cur_sign_fmt=$(git config --global gpg.format 2>/dev/null || echo "gpg")
_cur_email=$(git config --global user.email 2>/dev/null || echo "")

if [[ -n "$_cur_sign_key" ]]; then
  gum style --foreground 245 "  вҶ’ Current method: ${_cur_sign_fmt}"
  gum style --foreground 245 "  вҶ’ Current key: ${_cur_sign_key}"
else
  gum style --foreground 3 "  вҡ  No signing key configured"
fi

_sign_section_prompt="Configure commit signing?"
[[ -n "$_cur_sign_key" ]] && _sign_section_prompt="Change commit signing method?"
if gum confirm --show-help=false --affirmative "Yes" --negative "Skip" "$_sign_section_prompt"; then
  SIGN_MODE=$(gum choose --header "  Signing method:" "SSH key" "GPG key" "Disable signing")
  case "$SIGN_MODE" in
    "SSH key")
      _ssh_keys=()
      for _k in ~/.ssh/id_*; do
        [[ -f "$_k" ]] && [[ ! "$_k" =~ \.pub$ ]] && _ssh_keys+=("$_k")
      done
      if [[ ${#_ssh_keys[@]} -eq 0 ]]; then
        gum style --foreground 3 "  вҡ  No SSH private keys found in ~/.ssh"
        if gum confirm --show-help=false --affirmative "Generate one now" --negative "Skip" "  Generate a new ED25519 SSH key?"; then
          _new_key_email=$(git config --global user.email 2>/dev/null || echo "")
          if [[ -z "$_new_key_email" ]]; then
            _new_key_email=$(gum input --placeholder "your@email.com" --prompt "  Email for SSH key: ")
          fi
          _new_key_path="$HOME/.ssh/id_ed25519"
          if [[ -f "$_new_key_path" ]]; then
            _new_key_path=$(gum input --value "$HOME/.ssh/id_ed25519" --prompt "  Key path: ")
          fi
          if ssh-keygen -t ed25519 -C "$_new_key_email" -f "$_new_key_path" -N ""; then
            gum style --foreground 82 "вң”  SSH key generated: ${_new_key_path}.pub"
            _ssh_keys=("$_new_key_path")
          else
            gum style --foreground 1 "вңҳ  Key generation failed"
          fi
        fi
      fi
      if [[ ${#_ssh_keys[@]} -eq 0 ]]; then
        : # no keys available, skip
      else
        SIGN_KEY_PATH=$(printf '%s\n' "${_ssh_keys[@]}" | gum choose --header "  Select SSH key for signing:")
        SIGN_PUBKEY="${SIGN_KEY_PATH}.pub"
        if [[ ! -f "$SIGN_PUBKEY" ]]; then
          gum style --foreground 3 "  вҡ  Public key not found: $SIGN_PUBKEY"
        else
          git config --global gpg.format ssh
          git config --global user.signingkey "$SIGN_PUBKEY"
          git config --global commit.gpgsign true
          git config --global tag.gpgsign true
          gum style --foreground 245 "  вҶ’ SSH signing key: $SIGN_PUBKEY"
          ALLOWED_SIGNERS="${XDG_CONFIG_HOME:-$HOME/.config}/git/allowed_signers"
          mkdir -p "$(dirname "$ALLOWED_SIGNERS")"
          PUBKEY_CONTENT=$(cat "$SIGN_PUBKEY")
          if ! grep -qF "$PUBKEY_CONTENT" "$ALLOWED_SIGNERS" 2>/dev/null; then
            echo "${_cur_email:-unknown} $PUBKEY_CONTENT" >> "$ALLOWED_SIGNERS"
            gum style --foreground 245 "  вҶ’ Added key to allowed_signers: $ALLOWED_SIGNERS"
          fi
          git config --global gpg.ssh.allowedSignersFile "$ALLOWED_SIGNERS"
          gum style --foreground 82 "вң”  SSH signing configured"
          # Remember pubkey вҖ” will upload to GitHub after gh auth is confirmed
          _SSH_SIGNING_PUBKEY="$SIGN_PUBKEY"
        fi
      fi
      unset _ssh_keys _k
      ;;
    "GPG key")
      if ! command -v gpg &> /dev/null; then
        gum style --foreground 3 "  вҡ  gpg not installed вҖ” cannot configure GPG signing"
      else
        GPG_KEY=$(gpg --list-secret-keys --keyid-format LONG "${_cur_email}" 2>/dev/null \
          | grep "^sec" | awk -F'/' '{print $2}' | awk '{print $1}' || echo "")
        if [[ -z "$GPG_KEY" ]]; then
          GPG_KEY=$(gpg --list-secret-keys --keyid-format LONG 2>/dev/null \
            | grep "^sec" | awk -F'/' '{print $2}' | awk '{print $1}' | head -n1 || echo "")
        fi
        if [[ -n "$GPG_KEY" ]]; then
          git config --global gpg.format openpgp
          git config --global user.signingkey "$GPG_KEY"
          git config --global commit.gpgsign true
          git config --global tag.gpgsign true
          gum style --foreground 245 "  вҶ’ GPG signing key: $GPG_KEY"
          gum style --foreground 82 "вң”  GPG signing configured"
        else
          gum style --foreground 3 "  вҡ  No GPG secret key found"
        fi
      fi
      ;;
    "Disable signing")
      git config --global commit.gpgsign false
      git config --global tag.gpgsign false
      gum style --foreground 245 "  вҶ’ Commit signing disabled"
      gum style --foreground 82 "вң”  Signing disabled"
      ;;
  esac
else
  gum style --foreground 245 "  вҶ’ Skipped signing configuration"
fi
unset _cur_sign_key _cur_sign_fmt _cur_email _sign_section_prompt

#=== SSH Configuration ===
echo
echo -e "\e[36mвҡҷ  SSH Configuration\e[0m"
echo

# Check if SSH keys are available
SSH_KEYS_AVAILABLE=0
if ls ~/.ssh/id_* 2>/dev/null | grep -v '\.pub$' > /dev/null; then
  SSH_KEYS_AVAILABLE=1
  gum style --foreground 245 "  вҶ’ SSH keys found in ~/.ssh"
fi

# Ask if user wants to configure SSH
if [[ "$SSH_KEYS_AVAILABLE" -eq 1 ]]; then
  if ! gum confirm --show-help=false --affirmative "Yes" --negative "Skip" "Add SSH keys to agent?"; then
    gum style --foreground 245 "  вҶ’ Skipped SSH configuration"
    SKIP_SSH=1
  else
    SKIP_SSH=0
  fi
else
  gum style --foreground 3 "  вҡ  No SSH keys found in ~/.ssh"
  SKIP_SSH=1
fi

# Only proceed if user wants to configure SSH
if [[ "$SKIP_SSH" -eq 0 ]]; then
  # SSH keys are mounted directly at MOUNT_POINT (e.g., ~/.ssh)
  # No need to copy if mounting to ~/.ssh
  if [[ -n "$MOUNT_POINT" ]] && [[ "$MOUNT_POINT" != "$HOME/.ssh" ]] && [[ "$SKIP_VHD" -eq 0 ]]; then
    # Copy SSH keys if mounting to a different location
    if ls "$MOUNT_POINT"/id_* 2>/dev/null | grep -v '\.pub$' > /dev/null; then
      mkdir -p ~/.ssh
      cp "$MOUNT_POINT"/id_* ~/.ssh/
      chmod 700 ~/.ssh
      chmod 600 ~/.ssh/id_* 2>/dev/null || true
      gum style --foreground 245 "  вҶ’ SSH keys copied from $MOUNT_POINT"
    else
      gum style --foreground 3 "  вҡ  No SSH keys found in $MOUNT_POINT"
    fi
  fi

  # Load SSH keys вҖ” use keychain if available, otherwise fall back to ssh-add
  if command -v keychain &> /dev/null; then
    gum style --foreground 245 "  вҶ’ Loading SSH keys via keychain..."
    _kc_keys=()
    for _kc_key in ~/.ssh/id_*; do
      [[ -f "$_kc_key" ]] && [[ ! "$_kc_key" =~ \.pub$ ]] && _kc_keys+=("$_kc_key")
    done
    if [[ ${#_kc_keys[@]} -gt 0 ]]; then
      eval "$(keychain --dir "${KEYCHAIN_DIR:-$HOME/.ssh/.keychain}" --eval "${_kc_keys[@]}")"
    fi
    unset _kc_keys _kc_key
  else
    # Use SSH agent socket managed by systemd (configured in bash/envs)
    if [[ -S "${SSH_AUTH_SOCK:-}" ]]; then
      gum style --foreground 245 "  вҶ’ Using SSH agent at $SSH_AUTH_SOCK"
    else
      eval "$(ssh-agent -s)"
      gum style --foreground 245 "  вҶ’ SSH agent started (fallback)"
    fi

    # Add SSH keys (filter out .pub files to avoid the error)
    if ls ~/.ssh/id_* 2>/dev/null | grep -v '\.pub$' > /dev/null; then
      gum style --foreground 245 "  вҶ’ Adding SSH keys to agent..."
      # Only add private keys, not .pub files
      for key in ~/.ssh/id_*; do
        if [[ ! "$key" =~ \.pub$ ]]; then
          ssh-add "$key" 2>&1 | grep -v "Identity added" || true
        fi
      done
    fi
  fi

  # Check ~/.ssh/config for a valid github.com Host entry
  _ssh_cfg="$HOME/.ssh/config"
  _gh_host_found=0
  _gh_user_ok=0
  if [[ -f "$_ssh_cfg" ]]; then
    if awk '/^Host github\.com/{f=1} f && /^[[:space:]]+User[[:space:]]+git/{found=1} /^Host / && !/^Host github\.com/{f=0} END{exit !found}' "$_ssh_cfg" 2>/dev/null; then
      _gh_host_found=1
      _gh_user_ok=1
      gum style --foreground 245 "  вҶ’ ~/.ssh/config: github.com entry looks correct"
    elif grep -qE '^Host github\.com' "$_ssh_cfg" 2>/dev/null; then
      _gh_host_found=1
      gum style --foreground 3 "  вҡ  ~/.ssh/config has a github.com entry but 'User git' is missing"
    else
      gum style --foreground 3 "  вҡ  ~/.ssh/config has no github.com Host entry"
    fi
  else
    gum style --foreground 3 "  вҡ  ~/.ssh/config does not exist"
  fi

  if [[ "$_gh_user_ok" -eq 0 ]]; then
    _fix_msg="Add 'Host github.com' entry with User git to ~/.ssh/config?"
    [[ "$_gh_host_found" -eq 1 ]] && _fix_msg="Add 'User git' to the existing github.com entry in ~/.ssh/config?"
    if gum confirm --show-help=false --affirmative "Yes" --negative "Skip" "$_fix_msg"; then
      mkdir -p ~/.ssh
      chmod 700 ~/.ssh
      if [[ "$_gh_host_found" -eq 1 ]]; then
        # Insert 'User git' after the 'Host github.com' line
        sed -i '/^Host github\.com/a\\    User git' "$_ssh_cfg"
        gum style --foreground 245 "  вҶ’ Added 'User git' to existing github.com entry"
      else
        # Append a new block (with a blank line separator if file exists and is non-empty)
        [[ -s "$_ssh_cfg" ]] && echo "" >> "$_ssh_cfg"
        cat >> "$_ssh_cfg" <<'EOF'
Host github.com
    User git
    AddKeysToAgent yes
EOF
        chmod 600 "$_ssh_cfg"
        gum style --foreground 245 "  вҶ’ Added github.com Host entry to ~/.ssh/config"
      fi
    else
      gum style --foreground 245 "  вҶ’ Skipped ~/.ssh/config update"
    fi
  fi
  unset _ssh_cfg _gh_host_found _gh_user_ok _fix_msg

  gum style --foreground 82 "вң”  SSH configuration complete"
fi

#=== Update Git Remote to SSH ===
echo
echo -e "\e[36mвҡҷ  Git Remote Configuration\e[0m"
echo

# Ensure we're connected to the SSH agent (inherit from parent shell)
# SSH agent is typically already set up via systemd user service

# Check if we're in warchy directory
if [[ -d "$WARCHY_PATH/.git" ]]; then
  CURRENT_REMOTE=$(git -C "$WARCHY_PATH" remote get-url origin 2>/dev/null || echo "")
  
  if [[ -n "$CURRENT_REMOTE" ]]; then
    gum style --foreground 245 "  вҶ’ Current remote: $CURRENT_REMOTE"
    
    # Only ask if current remote is HTTPS
    if [[ "$CURRENT_REMOTE" =~ ^https://github.com/ ]]; then
      # Test SSH connection first
      gum style --foreground 245 "  вҶ’ Testing SSH connection to GitHub..."
      SSH_TEST_OUTPUT=$(timeout 5 ssh -o BatchMode=yes -o StrictHostKeyChecking=accept-new -T git@github.com 2>&1 || true)
      if echo "$SSH_TEST_OUTPUT" | grep -q "successfully authenticated"; then
        gum style --foreground 245 "  вҶ’ SSH connection verified"
        
        if gum confirm --show-help=false --affirmative "Yes" --negative "Skip" "Switch to SSH remote?"; then
          # Convert HTTPS to SSH format
          SSH_REMOTE=$(echo "$CURRENT_REMOTE" | sed 's|https://github.com/|git@github.com:|')
          git -C "$WARCHY_PATH" remote set-url origin "$SSH_REMOTE"
          gum style --foreground 245 "  вҶ’ Changed remote to SSH"
          gum style --foreground 245 "  вҶ’ New remote: $SSH_REMOTE"
        else
          gum style --foreground 245 "  вҶ’ Keeping HTTPS remote"
        fi
      else
        gum style --foreground 245 "  вҶ’ SSH not available: $SSH_TEST_OUTPUT"
      fi
    else
      gum style --foreground 245 "  вҶ’ Remote already using SSH"
    fi
  fi
else
  gum style --foreground 3 "  вҡ  Not in a git repository"
fi

#=== GitHub CLI Authentication ===
echo
echo -e "\e[36mвҡҷ  GitHub CLI Authentication\e[0m"
echo

GH_AUTH_CHANGED=0
if ! command -v gh &> /dev/null; then
  gum style --foreground 3 "  вҡ  GitHub CLI (gh) not installed"
else
  # Repair stale credential helper paths (gh may move between /usr/local/bin and /usr/sbin)
  if git config --global --get-all credential.https://github.com.helper 2>/dev/null | grep -qv "^$\|^!gh "; then
    git config --global --replace-all credential.https://github.com.helper ""
    git config --global --add credential.https://github.com.helper "!gh auth git-credential"
    git config --global --replace-all credential.https://gist.github.com.helper ""
    git config --global --add credential.https://gist.github.com.helper "!gh auth git-credential"
    gum style --foreground 245 "  вҶ’ Repaired git credential helper path"
  fi

  # Check if authenticated
  if gh auth status &>/dev/null; then
    gum style --foreground 245 "  вҶ’ GitHub CLI authenticated"
    
    # Verify authentication works with git operations
    WARCHY_REPO=$(git -C "$WARCHY_PATH" remote get-url origin 2>/dev/null | sed -E 's|https://github\.com/||;s|git@github\.com:||;s|\.git$||' || echo "")
    if [[ -n "$WARCHY_REPO" ]] && gh repo view "$WARCHY_REPO" &>/dev/null; then
      gum style --foreground 245 "  вҶ’ GitHub CLI can access repositories"
    else
      gum style --foreground 3 "  вҡ  GitHub CLI authenticated but cannot access repositories"
    fi
  else
    gum style --foreground 3 "  вҡ  GitHub CLI not authenticated"
    
    if gum confirm --show-help=false --affirmative "Yes" --negative "Skip" "Login to GitHub CLI now?"; then
      echo
      gh auth login
      GH_AUTH_CHANGED=1
    fi
  fi
fi

# Retry Git Remote Configuration if gh auth was just completed
if [[ "$GH_AUTH_CHANGED" -eq 1 ]] && [[ -d "$WARCHY_PATH/.git" ]]; then
  echo
  echo -e "\e[36mвҡҷ  Git Remote Configuration (Retry)\e[0m"
  echo
  
  CURRENT_REMOTE=$(git -C "$WARCHY_PATH" remote get-url origin 2>/dev/null || echo "")
  
  if [[ "$CURRENT_REMOTE" =~ ^https://github.com/ ]]; then
    gum style --foreground 245 "  вҶ’ Checking SSH after authentication..."
    # Test SSH connection to GitHub
    if ssh -T git@github.com 2>&1 | grep -q "successfully authenticated"; then
      # Convert HTTPS to SSH format
      SSH_REMOTE=$(echo "$CURRENT_REMOTE" | sed 's|https://github.com/|git@github.com:|')
      git -C "$WARCHY_PATH" remote set-url origin "$SSH_REMOTE"
      gum style --foreground 245 "  вҶ’ Changed remote to SSH"
      gum style --foreground 245 "  вҶ’ New remote: $SSH_REMOTE"
    else
      gum style --foreground 245 "  вҶ’ SSH still not available"
    fi
  fi
fi

# Upload SSH signing key to GitHub if one was configured this session
if [[ -n "$_SSH_SIGNING_PUBKEY" ]] && [[ -f "$_SSH_SIGNING_PUBKEY" ]] && command -v gh &>/dev/null && gh auth status &>/dev/null; then
  echo
  echo -e "\e[36mвҡҷ  GitHub SSH Signing Key\e[0m"
  echo
  _pending_pubkey_content=$(cat "$_SSH_SIGNING_PUBKEY")
  _pending_pubkey_fp=$(cut -d' ' -f2 <<< "$_pending_pubkey_content")
  if gh ssh-key list 2>/dev/null | grep -qF "$_pending_pubkey_fp"; then
    gum style --foreground 245 "  вҶ’ Signing key already on GitHub"
  else
    if gum confirm --show-help=false --affirmative "Yes" --negative "Skip" "Add signing key to your GitHub account?"; then
      _gh_key_title=$(gum input --value "$(hostname)-signing" --prompt "  Key title: ")
      if gh ssh-key add "$_SSH_SIGNING_PUBKEY" --title "$_gh_key_title" --type signing; then
        gum style --foreground 82 "вң”  SSH signing key added to GitHub"
      else
        gum style --foreground 1 "вңҳ  Failed to add key to GitHub"
      fi
    fi
  fi
  unset _pending_pubkey_content _pending_pubkey_fp _gh_key_title
fi
unset _SSH_SIGNING_PUBKEY

echo
gum style --foreground 82 "вң”  User configuration complete!"
echo
